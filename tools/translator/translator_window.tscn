base_url = "https://api.moonshot.cn/v1/chat/completions"
model = "moonshot-v1-32k"
stream = true
tool_mode = true
tool_message = "请你按照如下要求回复我的内容：
1. 中文自动翻译为英文，英文自动翻译为中文，其他语言自动翻译为中文。格式为\"翻译结果：<对应语言的翻译文字>\"
2. \"同义翻译: ok, good... \"
3. \"解释说明: ...\"
"
message_memory_limit = 2
